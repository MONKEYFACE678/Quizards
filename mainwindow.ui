#include "mainwindow.h"
#include "ui_mainwindow.h"

MainWindow::MainWindow(QWidget *parent)
    : QMainWindow(parent)
    , ui(new Ui::MainWindow)
{
    ui->setupUi(this);
}

MainWindow::~MainWindow()
{
    delete ui;
}

int answer, submitButton, result;

void MainWindow::on_submitButton_clicked()
{
    QString userGuess = ui->answer->text(); // Gets user input

    QString correctAnswer = "City"; // answer will need to be this exact word

    if (userGuess.trimmed().toLower() == correctAnswer.toLower()) {
        ui->resultLabel->setText("Great Job!");
    } else {
        ui->resultLabel->setText("Please try again!");
    } // trims and toLower allows user to put in entry and doesn't need exact punctuation

    ui->answer->clear(); // resets entry box
}
